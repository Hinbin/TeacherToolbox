<local:AutomatedPage
    x:Class="TeacherToolbox.Controls.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TeacherToolbox.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    DataContext="{Binding Source={StaticResource Locator}, Path=Settings}"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  Spacing between cards  -->
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <!--  Style (inc. the correct spacing) of a section header  -->
        <Style
            x:Key="SettingsSectionHeaderTextBlockStyle"
            BasedOn="{StaticResource BodyStrongTextBlockStyle}"
            TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,30,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="8">
            <!--  Page Header  -->
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Settings" />

            <!--  Feedback Section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Feedback" />

            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <local:ExpanderItem Header="Send Feedback" Subheader="Report bugs or request new features">
                    <local:ExpanderItem.ItemContent>
                        <Button
                            x:Name="SendFeedbackButton"
                            Command="{Binding SendFeedbackCommand}"
                            Content="Send Feedback" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="View Feedback" Subheader="Browse reported bugs and requests">
                    <local:ExpanderItem.ItemContent>
                        <Button
                            x:Name="ViewFeedbackButton"
                            Command="{Binding ViewFeedbackCommand}"
                            Content="View Feedback" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
            </StackPanel>

            <!--  Timer Section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Timer" />

            <!--  Settings Card  -->
            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <!--  Timer sound Setting  -->
                <local:ExpanderItem Header="Timer sound" Subheader="Select the sound when the timer is finished">
                    <local:ExpanderItem.ItemContent>
                        <ComboBox
                            x:Name="TimerSoundComboBox"
                            MinWidth="120"
                            DisplayMemberPath="Name"
                            ItemsSource="{Binding SoundOptions}"
                            SelectedIndex="{Binding SelectedTimerSoundIndex, Mode=TwoWay}" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Test Timer Sound" Subheader="Press the button to test the sound when the timer is finished">
                    <local:ExpanderItem.ItemContent>
                        <Button
                            x:Name="TimerSoundButton"
                            Command="{Binding TestSoundCommand}"
                            Content="Test Sound" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Timer finish behavior" Subheader="Select what happens when the timer finishes">
                    <local:ExpanderItem.ItemContent>
                        <ComboBox
                            x:Name="TimerFinishBehaviorComboBox"
                            MinWidth="120"
                            SelectedIndex="{Binding SelectedTimerFinishBehaviorIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Close timer" />
                            <ComboBoxItem Content="Count up" />
                            <ComboBoxItem Content="Stay at zero" />
                        </ComboBox>
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Timer ring colour" Subheader="Choose the colour of the running timer ring">
                    <local:ExpanderItem.ItemContent>
                        <Button
                            Width="40"
                            Height="40"
                            Padding="2"
                            ToolTipService.ToolTip="Click to change colour">
                            <Rectangle
                                Width="32"
                                Height="32"
                                RadiusX="3"
                                RadiusY="3"
                                Fill="{Binding TimerRingBrush}" />
                            <Button.Flyout>
                                <Flyout Placement="Bottom">
                                    <ColorPicker
                                        Color="{Binding TimerRingColor, Mode=TwoWay}"
                                        IsAlphaEnabled="False"
                                        IsColorPreviewVisible="True"
                                        IsHexInputVisible="True" />
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
            </StackPanel>

            <!--  Appearance Section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Appearance" />

            <!--  Settings Card  -->
            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <!--  App Theme Setting  -->
                <local:ExpanderItem Header="App theme" Subheader="Select which app theme to display">
                    <local:ExpanderItem.ItemContent>
                        <ComboBox
                            x:Name="ThemeComboBox"
                            MinWidth="120"
                            SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="Use system setting" />
                            <ComboBoxItem Content="Light" />
                            <ComboBoxItem Content="Dark" />
                        </ComboBox>
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            </StackPanel>

            <!--  About Section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="About" />

            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <local:ExpanderItem Header="About">
                    <local:ExpanderItem.ItemContent>
                        <StackPanel Spacing="10">
                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="Teacher Toolbox" FontWeight="Bold" />
                            <TextBlock Style="{StaticResource BodyTextBlockStyle}" Text="{x:Bind ViewModel.AppVersion, Mode=OneTime}" />
                            <Button Content="Save diagnostic logs"
                                    Command="{x:Bind ViewModel.SaveLogsCommand}"
                                    Margin="0,10,0,0" />
                            <Button Content="Test Crash"
                                    Command="{x:Bind ViewModel.TestCrashCommand}"
                                    Visibility="{x:Bind ViewModel.IsDebugVisible, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Background="OrangeRed" Foreground="White"
                                    Margin="0,10,0,0" />
                        </StackPanel>
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</local:AutomatedPage>