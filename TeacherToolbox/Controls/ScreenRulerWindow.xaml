<?xml version="1.0" encoding="utf-8" ?>
<winex:WindowEx
    x:Class="TeacherToolbox.Controls.ScreenRulerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TeacherToolbox.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winex="using:WinUIEx"
    mc:Ignorable="d">

    <Grid
        PointerMoved="Grid_PointerMoved"
        PointerPressed="Grid_PointerPressed"
        PointerReleased="Grid_PointerReleased">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Rectangle
            x:Name="ruler"
            Grid.ColumnSpan="2"
            AutomationProperties.AutomationId="ScreenRulerRectangle"
            AutomationProperties.Name="Screen Ruler Rectangle"
            Fill="#FF5b3493"
            Stroke="Black"
            StrokeThickness="1" />
        <Button
            x:Name="closeButton"
            Grid.Column="1"
            Margin="0,10,10,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            AutomationProperties.AutomationId="ScreenRulerCloseButton"
            AutomationProperties.Name="Screen Ruler Close Button"
            Background="Transparent"
            BorderThickness="0"
            Click="CloseButton_Click">

            <FontIcon
                FontFamily="Segoe MDL2 Assets"
                Foreground="Black"
                Glyph="&#xE711;" />
        </Button>

        <Border
            x:Name="resizeHandle"
            Grid.ColumnSpan="2"
            Width="96"
            Height="24"
            Margin="0,0,0,4"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            AutomationProperties.AutomationId="ScreenRulerResizeHandle"
            AutomationProperties.Name="Screen Ruler Resize Handle"
            Background="#FF3F2468"
            BorderBrush="Black"
            BorderThickness="1"
            CornerRadius="4"
            PointerMoved="ResizeHandle_PointerMoved"
            PointerPressed="ResizeHandle_PointerPressed"
            PointerReleased="ResizeHandle_PointerReleased">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="3">
                <Rectangle
                    Width="44"
                    Height="2"
                    Fill="White"
                    Opacity="0.85" />
                <Rectangle
                    Width="32"
                    Height="2"
                    Fill="White"
                    Opacity="0.85" />
                <Rectangle
                    Width="20"
                    Height="2"
                    Fill="White"
                    Opacity="0.85" />
            </StackPanel>
        </Border>
    </Grid>

</winex:WindowEx>
