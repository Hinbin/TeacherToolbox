<?xml version="1.0" encoding="utf-8" ?>
<local:AutomatedPage
    x:Class="TeacherToolbox.Controls.RegisterReminderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TeacherToolbox.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TeacherToolbox.ViewModels"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="8">

            <!--  Page Header  -->
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Register Reminder" />

            <!--  General section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="General" />

            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <local:ExpanderItem Header="Enable reminders" Subheader="Turn register reminders on or off">
                    <local:ExpanderItem.ItemContent>
                        <ToggleSwitch
                            x:Name="MasterEnabledToggle"
                            AutomationProperties.AutomationId="MasterEnabledToggle"
                            IsOn="{x:Bind ViewModel.MasterEnabled, Mode=TwoWay}"
                            OffContent=""
                            OnContent="" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Snooze duration" Subheader="Minutes before a snoozed reminder fires again">
                    <local:ExpanderItem.ItemContent>
                        <NumberBox
                            x:Name="SnoozeNumberBox"
                            AutomationProperties.AutomationId="SnoozeNumberBox"
                            Maximum="30"
                            Minimum="1"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.SnoozeMinutes, Mode=TwoWay}" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Reminder sound" Subheader="Sound played when a reminder fires">
                    <local:ExpanderItem.ItemContent>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox
                                x:Name="SoundComboBox"
                                MinWidth="140"
                                AutomationProperties.AutomationId="ReminderSoundComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{x:Bind ViewModel.SoundOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedSoundIndex, Mode=TwoWay}" />
                            <Button
                                x:Name="TestSoundButton"
                                AutomationProperties.AutomationId="TestReminderSoundButton"
                                Command="{x:Bind ViewModel.TestSoundCommand}"
                                Content="Test" />
                        </StackPanel>
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            </StackPanel>

            <!--  Setup hint – visible whenever the master toggle is off  -->
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.ShowSetupInfo, Mode=OneWay}"
                Message="Flip the 'Enable reminders' switch above to start getting notified."
                Severity="Informational"
                Title="Reminders are disabled" />

            <!--  Reminder slots section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Reminder Times" />

            <ItemsControl
                Margin="0,8,0,0"
                x:Name="SlotsControl"
                ItemsSource="{x:Bind ViewModel.Slots}">
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReminderSlotViewModel">
                        <Expander
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            IsExpanded="True">
                            <Expander.Header>
                                <TextBlock
                                    Style="{StaticResource BodyStrongTextBlockStyle}"
                                    Text="{x:Bind DisplayLabel, Mode=OneWay}" />
                            </Expander.Header>

                            <StackPanel Padding="16,4,16,12" Spacing="6">

                                <TextBox PlaceholderText="Label (optional)" Text="{x:Bind Label, Mode=TwoWay}" />

                                <!--  Monday  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        IsChecked="{x:Bind Monday.Enabled, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="Mon" />
                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Monday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Monday.HourOptions}"
                                        SelectedItem="{x:Bind Monday.Hour, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text=":" />
                                    <ComboBox
                                        Grid.Column="4"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Monday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Monday.MinuteOptions}"
                                        SelectedItem="{x:Bind Monday.Minute, Mode=TwoWay}" />
                                </Grid>

                                <!--  Tuesday  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        IsChecked="{x:Bind Tuesday.Enabled, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="Tue" />
                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Tuesday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Tuesday.HourOptions}"
                                        SelectedItem="{x:Bind Tuesday.Hour, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text=":" />
                                    <ComboBox
                                        Grid.Column="4"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Tuesday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Tuesday.MinuteOptions}"
                                        SelectedItem="{x:Bind Tuesday.Minute, Mode=TwoWay}" />
                                </Grid>

                                <!--  Wednesday  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        IsChecked="{x:Bind Wednesday.Enabled, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="Wed" />
                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Wednesday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Wednesday.HourOptions}"
                                        SelectedItem="{x:Bind Wednesday.Hour, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text=":" />
                                    <ComboBox
                                        Grid.Column="4"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Wednesday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Wednesday.MinuteOptions}"
                                        SelectedItem="{x:Bind Wednesday.Minute, Mode=TwoWay}" />
                                </Grid>

                                <!--  Thursday  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        IsChecked="{x:Bind Thursday.Enabled, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="Thu" />
                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Thursday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Thursday.HourOptions}"
                                        SelectedItem="{x:Bind Thursday.Hour, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text=":" />
                                    <ComboBox
                                        Grid.Column="4"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Thursday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Thursday.MinuteOptions}"
                                        SelectedItem="{x:Bind Thursday.Minute, Mode=TwoWay}" />
                                </Grid>

                                <!--  Friday  -->
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="60" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox
                                        Grid.Column="0"
                                        MinWidth="0"
                                        IsChecked="{x:Bind Friday.Enabled, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Text="Fri" />
                                    <ComboBox
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Friday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Friday.HourOptions}"
                                        SelectedItem="{x:Bind Friday.Hour, Mode=TwoWay}" />
                                    <TextBlock
                                        Grid.Column="3"
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text=":" />
                                    <ComboBox
                                        Grid.Column="4"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{x:Bind Friday.Enabled, Mode=OneWay}"
                                        ItemsSource="{x:Bind Friday.MinuteOptions}"
                                        SelectedItem="{x:Bind Friday.Minute, Mode=TwoWay}" />
                                </Grid>

                                <Button
                                    Margin="0,6,0,0"
                                    Command="{x:Bind RemoveCommand}"
                                    Content="Remove period" />

                            </StackPanel>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button
                Command="{x:Bind ViewModel.AddSlotCommand}"
                Content="+ Add period" />

        </StackPanel>
    </ScrollViewer>
</local:AutomatedPage>
