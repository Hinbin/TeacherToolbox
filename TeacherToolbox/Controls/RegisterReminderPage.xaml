<?xml version="1.0" encoding="utf-8" ?>
<local:AutomatedPage
    x:Class="TeacherToolbox.Controls.RegisterReminderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TeacherToolbox.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:TeacherToolbox.ViewModels"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Margin="16" Spacing="8">

            <!--  Page Header  -->
            <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Register Reminder" />

            <!--  General section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="General" />

            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <local:ExpanderItem Header="Enable reminders" Subheader="Turn register reminders on or off">
                    <local:ExpanderItem.ItemContent>
                        <ToggleSwitch
                            x:Name="MasterEnabledToggle"
                            AutomationProperties.AutomationId="MasterEnabledToggle"
                            IsOn="{x:Bind ViewModel.MasterEnabled, Mode=TwoWay}"
                            OffContent=""
                            OnContent="" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Snooze duration" Subheader="Minutes before a snoozed reminder fires again">
                    <local:ExpanderItem.ItemContent>
                        <NumberBox
                            x:Name="SnoozeNumberBox"
                            AutomationProperties.AutomationId="SnoozeNumberBox"
                            Maximum="30"
                            Minimum="1"
                            SmallChange="1"
                            SpinButtonPlacementMode="Inline"
                            Value="{x:Bind ViewModel.SnoozeMinutes, Mode=TwoWay}" />
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

                <local:ExpanderItem Header="Reminder sound" Subheader="Sound played when a reminder fires">
                    <local:ExpanderItem.ItemContent>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox
                                x:Name="SoundComboBox"
                                MinWidth="140"
                                AutomationProperties.AutomationId="ReminderSoundComboBox"
                                DisplayMemberPath="Name"
                                ItemsSource="{x:Bind ViewModel.SoundOptions}"
                                SelectedIndex="{x:Bind ViewModel.SelectedSoundIndex, Mode=TwoWay}" />
                            <Button
                                x:Name="TestSoundButton"
                                AutomationProperties.AutomationId="TestReminderSoundButton"
                                Command="{x:Bind ViewModel.TestSoundCommand}"
                                Content="Test" />
                        </StackPanel>
                    </local:ExpanderItem.ItemContent>
                </local:ExpanderItem>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            </StackPanel>

            <!--  Setup hint – visible whenever the master toggle is off  -->
            <InfoBar
                IsClosable="False"
                IsOpen="{x:Bind ViewModel.ShowSetupInfo, Mode=OneWay}"
                Message="Flip the 'Enable reminders' switch above to start getting notified."
                Severity="Informational"
                Title="Reminders are disabled" />

            <!--  Reminder slots section  -->
            <TextBlock
                Margin="0,16,0,0"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Text="Reminder Times" />

            <StackPanel
                Margin="0,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">

                <ItemsControl x:Name="SlotsControl" ItemsSource="{x:Bind ViewModel.Slots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ReminderSlotViewModel">
                            <Grid Margin="0,1" Padding="16,10,16,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!--  Hour picker  -->
                                <ComboBox
                                    Grid.Column="0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    ItemsSource="{x:Bind HourOptions}"
                                    SelectedItem="{x:Bind Hour, Mode=TwoWay}" />

                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Text=":" />

                                <!--  Minute picker  -->
                                <ComboBox
                                    Grid.Column="4"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Center"
                                    ItemsSource="{x:Bind MinuteOptions}"
                                    SelectedItem="{x:Bind Minute, Mode=TwoWay}" />

                                <StackPanel
                                    Grid.Column="6"
                                    VerticalAlignment="Center"
                                    Spacing="6">
                                    <!--  Label TextBox  -->
                                    <TextBox
                                        PlaceholderText="Label (optional)"
                                        Text="{x:Bind Label, Mode=TwoWay}" />

                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <CheckBox
                                            MinWidth="34"
                                            Content="M"
                                            IsChecked="{x:Bind Monday, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="34"
                                            Content="T"
                                            IsChecked="{x:Bind Tuesday, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="34"
                                            Content="W"
                                            IsChecked="{x:Bind Wednesday, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="34"
                                            Content="T"
                                            IsChecked="{x:Bind Thursday, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="34"
                                            Content="F"
                                            IsChecked="{x:Bind Friday, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="34"
                                            Content="S"
                                            IsChecked="{x:Bind Saturday, Mode=TwoWay}" />
                                        <CheckBox
                                            MinWidth="34"
                                            Content="S"
                                            IsChecked="{x:Bind Sunday, Mode=TwoWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</local:AutomatedPage>
